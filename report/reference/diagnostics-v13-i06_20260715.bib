AUTHOR = {García-Murillo, Daniel Guillermo and Álvarez-Meza, Andrés Marino and Castellanos-Dominguez, Cesar German},
TITLE = {KCS-FCnet: Kernel Cross-Spectral Functional Connectivity Network for EEG-Based Motor Imagery Classification},
JOURNAL = {Diagnostics},
VOLUME = {13},
YEAR = {2023},
NUMBER = {6},
