<mxfile host="app.diagrams.net" modified="2026-07-15T00:00:00.000Z" agent="Codex" version="24.7.17"><diagram id="bciciv-split" name="Page-1"><mxGraphModel dx="1365" dy="767" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1333" pageHeight="560" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="&lt;b&gt;BCICIV 实验数据划分&lt;/b&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:12px'&gt;训练、会话校准与最终评估严格隔离&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=none;strokeColor=none;strokeWidth=0;fontColor=#203047;fontSize=24;" vertex="1" parent="1"><mxGeometry x="40" y="25" width="1250" height="65" as="geometry" /></mxCell><mxCell id="input" value="&lt;b&gt;MI 窗口&lt;/b&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:11px'&gt;三类任务&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#EEF3F8;strokeColor=#3478B8;strokeWidth=2;fontColor=#203047;fontSize=14;" vertex="1" parent="1"><mxGeometry x="40" y="225" width="125" height="90" as="geometry" /></mxCell><mxCell id="train" value="&lt;b&gt;TRAIN&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:28px'&gt;&lt;b&gt;840&lt;/b&gt;&lt;/font&gt;&lt;br&gt;训练 FBCSP、Embedding&lt;br&gt;与经验库候选 Heads&lt;br&gt;&lt;font style='font-size:11px'&gt;拟合模型参数&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#3478B8;strokeColor=#3478B8;strokeWidth=2;fontColor=#FFFFFF;fontSize=15;" vertex="1" parent="1"><mxGeometry x="205" y="145" width="315" height="235" as="geometry" /></mxCell><mxCell id="cal" value="&lt;b&gt;CALIBRATION&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:28px'&gt;&lt;b&gt;42&lt;/b&gt;&lt;/font&gt;&lt;br&gt;候选评分与 Top-K 选择&lt;br&gt;形成当前会话组合&lt;br&gt;&lt;font style='font-size:11px'&gt;不计入最终评估&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#E58A2B;strokeColor=#E58A2B;strokeWidth=2;fontColor=#FFFFFF;fontSize=15;" vertex="1" parent="1"><mxGeometry x="570" y="145" width="315" height="235" as="geometry" /></mxCell><mxCell id="eval" value="&lt;b&gt;EVALUATION&lt;/b&gt;&lt;br&gt;&lt;font style='font-size:28px'&gt;&lt;b&gt;518&lt;/b&gt;&lt;/font&gt;&lt;br&gt;计算最终 Accuracy、Balanced&lt;br&gt;Accepted 与 Reject 指标&lt;br&gt;&lt;font style='font-size:11px'&gt;不参与训练或候选选择&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#3C9064;strokeColor=#3C9064;strokeWidth=2;fontColor=#FFFFFF;fontSize=15;" vertex="1" parent="1"><mxGeometry x="935" y="145" width="315" height="235" as="geometry" /></mxCell><mxCell id="isolation" value="&lt;b&gt;评估集不用于模型训练　｜　评估集不用于 Top-K 选择&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#FFF3F3;strokeColor=#E6A3A3;strokeWidth=1;fontColor=#C95757;fontSize=14;" vertex="1" parent="1"><mxGeometry x="205" y="420" width="680" height="50" as="geometry" /></mxCell><mxCell id="fair" value="&lt;b&gt;相同评估窗口 · 公平对比&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#EDF7F1;strokeColor=#A5CFB6;strokeWidth=1;fontColor=#3C9064;fontSize=13;" vertex="1" parent="1"><mxGeometry x="935" y="420" width="315" height="50" as="geometry" /></mxCell><mxCell id="note" value="口径：Reject 是系统依据置信度产生的输出，不是数据集中的第四类标签。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=none;strokeColor=none;strokeWidth=0;fontColor=#667487;fontSize=12;" vertex="1" parent="1"><mxGeometry x="40" y="500" width="1210" height="30" as="geometry" /></mxCell><mxCell id="e1" style="edgeStyle=o