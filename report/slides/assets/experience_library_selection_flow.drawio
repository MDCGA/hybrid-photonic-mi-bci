        <mxCell id="calibration" value="&lt;b&gt;42 个校准窗口&lt;/b&gt;&lt;br&gt;目标会话 EEG&lt;br&gt;不计入最终评估" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#3478B8;strokeColor=#3478B8;fontColor=#FFFFFF;fontSize=16;align=center;verticalAlign=middle;" vertex="1" parent="1">
