  <diagram id="experience-library-flow" name="经验库会话特化流程">
    <mxGraphModel dx="1300" dy="420" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1400" pageHeight="500" math="1" shadow="0">
