<mxfile host="app.diagrams.net" modified="2026-07-16T00:00:00.000Z" agent="Codex" version="24.7.17"><diagram id="project-questions" name="Page-1"><mxGraphModel dx="1365" dy="767" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1333" pageHeight="750" math="0" shadow="0"><root><mxCell id="0" /><mxCell id="1" parent="0" /><mxCell id="title" value="&lt;b&gt;从真实使用约束出发：我们需要回答什么？&lt;/b&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:12px'&gt;从 MI-EEG 个体差异，到光计算执行，再到可用的在线闭环&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=none;strokeColor=none;strokeWidth=0;fontColor=#203047;fontSize=24;" vertex="1" parent="1"><mxGeometry x="45" y="25" width="1240" height="70" as="geometry" /></mxCell><mxCell id="group0" value="&lt;b&gt;需求动机&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=none;strokeColor=#3478B8;strokeWidth=0;fontColor=#3478B8;fontSize=13;" vertex="1" parent="1"><mxGeometry x="45" y="110" width="380" height="35" as="geometry" /></mxCell><mxCell id="group1" value="&lt;b&gt;计算方案&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=none;strokeColor=#7656A8;strokeWidth=0;fontColor=#7656A8;fontSize=13;" vertex="1" parent="1"><mxGeometry x="475" y="110" width="380" height="35" as="geometry" /></mxCell><mxCell id="group2" value="&lt;b&gt;使用落地&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=none;strokeColor=#3C9064;strokeWidth=0;fontColor=#3C9064;fontSize=13;" vertex="1" parent="1"><mxGeometry x="905" y="110" width="380" height="35" as="geometry" /></mxCell><mxCell id="q0" value="&lt;table cellpadding='0' cellspacing='0' width='100%'&gt;&lt;tr&gt;&lt;td width='52' bgcolor='#3478B8'&gt;&lt;font color='#FFFFFF'&gt;&lt;b&gt;01&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td align='left' style='padding-left:10px'&gt;&lt;b&gt;为什么需要经验库？&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:12px'&gt;个体 / 会话差异明显&lt;br&gt;固定全局模型难以覆盖所有使用者&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#F7F9FB;strokeColor=#CAD5E1;strokeWidth=1;fontColor=#203047;fontSize=15;" vertex="1" parent="1"><mxGeometry x="45" y="165" width="380" height="170" as="geometry" /></mxCell><mxCell id="q1" value="&lt;table cellpadding='0' cellspacing='0' width='100%'&gt;&lt;tr&gt;&lt;td width='52' bgcolor='#C95757'&gt;&lt;font color='#FFFFFF'&gt;&lt;b&gt;02&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td align='left' style='padding-left:10px'&gt;&lt;b&gt;为什么需要拒识？&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:12px'&gt;非目标状态；光 / 声 / 触觉 / 情绪刺激&lt;br&gt;可能掩盖 MI，低置信度不强制输出&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#F7F9FB;strokeColor=#CAD5E1;strokeWidth=1;fontColor=#203047;fontSize=15;" vertex="1" parent="1"><mxGeometry x="45" y="390" width="380" height="170" as="geometry" /></mxCell><mxCell id="q2" value="&lt;table cellpadding='0' cellspacing='0' width='100%'&gt;&lt;tr&gt;&lt;td width='52' bgcolor='#7656A8'&gt;&lt;font color='#FFFFFF'&gt;&lt;b&gt;03&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td align='left' style='padding-left:10px'&gt;&lt;b&gt;为什么适合光计算？&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:12px'&gt;滤波、空间投影、MLP 与扫描&lt;br&gt;包含大量可统一表达的线性计算&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#F7F9FB;strokeColor=#CAD5E1;strokeWidth=1;fontColor=#203047;fontSize=15;" vertex="1" parent="1"><mxGeometry x="475" y="165" width="380" height="170" as="geometry" /></mxCell><mxCell id="q3" value="&lt;table cellpadding='0' cellspacing='0' width='100%'&gt;&lt;tr&gt;&lt;td width='52' bgcolor='#E58A2B'&gt;&lt;font color='#FFFFFF'&gt;&lt;b&gt;04&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td align='left' style='padding-left:10px'&gt;&lt;b&gt;为什么扫描多个候选头？&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:12px'&gt;低功耗并行 / 快速扫描小型模型&lt;br&gt;以候选组合支持当前会话特化&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#F7F9FB;strokeColor=#CAD5E1;strokeWidth=1;fontColor=#203047;fontSize=15;" vertex="1" parent="1"><mxGeometry x="475" y="390" width="380" height="170" as="geometry" /></mxCell><mxCell id="q4" value="&lt;table cellpadding='0' cellspacing='0' width='100%'&gt;&lt;tr&gt;&lt;td width='52' bgcolor='#3C9064'&gt;&lt;font color='#FFFFFF'&gt;&lt;b&gt;05&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td align='left' style='padding-left:10px'&gt;&lt;b&gt;实际使用流程是什么？&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:12px'&gt;Cyton 采集 → 上位机校准 → 经验库&lt;br&gt;在线推理 → 命令输出 / 拒识&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#F7F9FB;strokeColor=#CAD5E1;strokeWidth=1;fontColor=#203047;fontSize=15;" vertex="1" parent="1"><mxGeometry x="905" y="165" width="380" height="170" as="geometry" /></mxCell><mxCell id="q5" value="&lt;table cellpadding='0' cellspacing='0' width='100%'&gt;&lt;tr&gt;&lt;td width='52' bgcolor='#2F8791'&gt;&lt;font color='#FFFFFF'&gt;&lt;b&gt;06&lt;/b&gt;&lt;/font&gt;&lt;/td&gt;&lt;td align='left' style='padding-left:10px'&gt;&lt;b&gt;当前工程边界是什么？&lt;/b&gt;&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;&lt;br&gt;&lt;font color='#667487' style='font-size:12px'&gt;在线采集与上位机仍在完善&lt;br&gt;尚未完成真实被试闭环验证&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#F7F9FB;strokeColor=#CAD5E1;strokeWidth=1;fontColor=#203047;fontSize=15;" vertex="1" parent="1"><mxGeometry x="905" y="390" width="380" height="170" as="geometry" /></mxCell><mxCell id="mainline" value="&lt;b&gt;设计主线：会话特化经验库 × 置信度拒识 × 前向线性计算接管&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=#EEF3F8;strokeColor=#CAD5E1;strokeWidth=1;fontColor=#203047;fontSize=15;" vertex="1" parent="1"><mxGeometry x="45" y="610" width="1240" height="60" as="geometry" /></mxCell><mxCell id="status" value="当前状态：公开数据离线回放与软件模拟已完成；Cyton 上位机、在线采集和真实被试闭环仍在完善。" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;align=center;verticalAlign=middle;fontFamily=Microsoft YaHei;fillColor=none;strokeColor=none;strokeWidth=0;fontColor=#667487;fontSize=11;" vertex="1" parent="1"><mxGeometry x="45" y="690" width="1240" height="30" as="geometry" /></mxCell></root></mxGraphModel></diagram></mxfile>